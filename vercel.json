{
  "functions": {
    "api/**/*.py": {
      "runtime": "@vercel/python"
    }
  },
  "routes": [
    {
      "src": "/api/v1/(.*)",
      "dest": "/api/v1/chat.py"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/v1/chat.py"
    }
  ],
  "env": {
    "GEMINI_API_KEY": "@gemini-api-key"
  },
  "build": {
    "env": {
      "PIP_INSTALL_PACKAGES": "fastapi uvicorn google-generativeai sentence-transformers numpy scikit-learn pydantic python-dotenv"
    }
  }
}
